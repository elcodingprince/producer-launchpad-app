# Shopify API credentials - Get these from your Shopify Partner Dashboard
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_APP_URL=https://your-app-url.com
SHOPIFY_APP_SCOPES=read_products,write_products,read_publications,write_publications,read_metaobjects,write_metaobjects,read_shop

# Session secret - Generate a random 32+ character string
SESSION_SECRET=your_random_session_secret_here

# BunnyCDN Configuration - Get these from your BunnyCDN dashboard
BUNNY_STORAGE_ZONE=your-storage-zone-name
BUNNY_STORAGE_PASSWORD=your-storage-password
BUNNY_PULL_ZONE=your-pull-zone.b-cdn.net
BUNNY_REGION=ny

# Database URL for session storage
DATABASE_URL="file:./prisma/dev.sqlite"
