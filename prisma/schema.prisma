generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model ShopStorageConfig {
  id                 String   @id @default(cuid())
  shop               String   @unique
  mode               String   @default("disconnected")
  provider           String?
  status             String   @default("disconnected")
  accountId          String?
  bucketName         String?
  publicBaseUrl      String?
  accessKeyIdEnc     String?
  secretAccessKeyEnc String?
  lastTestedAt       DateTime?
  lastError          String?
  errorType          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BeatFile {
  id          String   @id @default(cuid())
  beatId      String   // Shopify product ID or internal beat identifier
  filename    String
  storageUrl  String
  fileType    String   // audio/mpeg, audio/wav, application/zip, image/jpeg, etc.
  filePurpose String   // preview, mp3, wav, stems, cover, license_pdf
  size        Int      // file size in bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  licenseMappings LicenseFileMapping[]

  @@index([beatId])
  @@index([beatId, filePurpose])
}

model LicenseFileMapping {
  id           String   @id @default(cuid())
  variantId    String   // Shopify product variant ID
  fileId       String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  beatFile     BeatFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([fileId])
}

model Order {
  id              String   @id @default(cuid())
  shop            String
  shopifyOrderId  String   @unique
  orderNumber     String
  customerEmail   String
  customerName    String?
  downloadToken   String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  status          String   @default("active")

  items           OrderItem[]

  @@index([shop, shopifyOrderId])
  @@index([downloadToken])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  shopifyLineId   String
  productId       String
  variantId       String
  beatTitle       String
  licenseName     String
  downloadCount   Int      @default(0)
  createdAt       DateTime @default(now())

  // Relations
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([variantId])
}
