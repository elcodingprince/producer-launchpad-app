generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
}

model ShopStorageConfig {
  id                 String    @id @default(cuid())
  shop               String    @unique
  mode               String    @default("disconnected")
  provider           String?
  status             String    @default("disconnected")
  accountId          String?
  bucketName         String?
  publicBaseUrl      String?
  accessKeyIdEnc     String?
  secretAccessKeyEnc String?
  lastTestedAt       DateTime?
  lastError          String?
  errorType          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model ShopCatalogConfig {
  id                  String   @id @default(cuid())
  shop                String   @unique
  stemsAddonProductId String?
  stemsAddonVariantId String?
  stemsAddonHandle    String?
  stemsAddonTitle     String?
  stemsAddonPrice     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BeatFile {
  id          String   @id @default(cuid())
  shop        String   @default("")
  beatId      String // Shopify product ID or internal beat identifier
  filename    String
  storageUrl  String
  storageKey  String?
  fileType    String // audio/mpeg, audio/wav, application/zip, image/jpeg, etc.
  filePurpose String // preview, mp3, wav, stems, cover, license_pdf
  size        Int // file size in bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  licenseMappings LicenseFileMapping[]

  @@index([beatId])
  @@index([beatId, filePurpose])
  @@index([shop])
  @@index([shop, beatId, filePurpose])
}

model BeatDraft {
  id                       String   @id @default(cuid())
  shop                     String
  title                    String
  bpm                      Int?
  key                      String?
  producerAlias            String?
  genreGidsJson            String   @default("[]")
  producerGidsJson         String   @default("[]")
  licenseFilesJson         String   @default("{}")
  licensePricesJson        String   @default("{}")
  stemsAddonSelectionsJson String   @default("{}")
  uploadedFilesJson        String   @default("[]")
  previewFileJson          String?
  coverArtFileJson         String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([shop])
  @@index([shop, updatedAt])
}

model LicenseFileMapping {
  id        String   @id @default(cuid())
  variantId String // Shopify product variant ID
  fileId    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  beatFile BeatFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([fileId])
}

model Order {
  id             String   @id @default(cuid())
  shop           String
  shopifyOrderId String   @unique
  orderNumber    String
  browserIp      String?
  userAgent      String?
  acceptLanguage String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  status         String   @default("active")

  items          OrderItem[]
  deliveryAccess DeliveryAccess?
  executedAgreements ExecutedAgreement[]

  @@index([shop, shopifyOrderId])
}

model OrderItem {
  id                   String   @id @default(cuid())
  orderId              String
  shopifyLineId        String
  productId            String
  variantId            String
  beatTitle            String
  licenseName          String
  stemsIncludedInOrder Boolean  @default(false)
  downloadCount        Int      @default(0)
  createdAt            DateTime @default(now())

  // Relations
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  executedAgreement  ExecutedAgreement?

  @@index([orderId])
  @@index([variantId])
}

model ExecutedAgreement {
  id                    String   @id @default(cuid())
  shop                  String
  orderId               String
  orderItemId           String   @unique
  templateMetaobjectId  String?
  templateHandle        String
  offerArchetype        String
  templateVersion       String?
  acceptedAt            DateTime?
  acceptedTemplateVersion String?
  acceptedTemplateHash  String?
  acceptedLicenseName   String?
  acceptedDeliveryPackage String?
  acceptedProofJson     String?
  acceptedSnapshotMatch Boolean?
  resolvedLicenseJson   String
  beatOfferSnapshotJson String
  stemsIncludedInOrder  Boolean  @default(false)
  licensorSnapshotJson  String
  renderedHtml          String
  htmlHash              String
  pdfData               Bytes?
  pdfHash               String?
  pdfStatus             String   @default("pending")
  pdfError              String?
  buyerEmail            String?
  buyerIp               String?
  userAgent             String?
  purchasedAt           DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([shop])
  @@index([orderId])
  @@index([templateHandle])
  @@index([purchasedAt])
}

model DeliveryAccess {
  id                           String    @id @default(cuid())
  orderId                      String    @unique
  shop                         String
  customerEmail                String
  customerName                 String?
  downloadToken                String    @unique
  deliveryEmailStatus          String    @default("pending")
  deliveryEmailSentAt          DateTime?
  deliveryEmailError           String?
  deliveryEmailRecipient       String?
  deliveryEmailMessageId       String?
  deliveryEmailConfirmedStatus String?
  deliveryEmailConfirmedAt     DateTime?
  deliveryEmailConfirmedError  String?
  deliveryEmailLastEvent       String?
  deliveryEmailLastEventAt     DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([shop])
  @@index([downloadToken])
}

model PrivacyDataRequest {
  id                   String   @id @default(cuid())
  shop                 String
  shopifyDataRequestId String
  shopifyCustomerId    String?
  customerEmail        String?
  ordersRequestedJson  String   @default("[]")
  requestPayloadJson   String
  exportJson           String?
  status               String   @default("pending")
  fulfilledAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([shop, shopifyDataRequestId])
  @@index([shop, status])
  @@index([shop, customerEmail])
}

model TemplateGuardrailAcceptance {
  id                   String   @id @default(cuid())
  shop                 String
  templateHandle       String
  templateMetaobjectId String
  starterVersion       String
  acceptedAt           DateTime
  acceptedByUserId     BigInt?
  acceptedByEmail      String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([shop, templateHandle, starterVersion])
  @@index([shop])
  @@index([templateHandle])
}
